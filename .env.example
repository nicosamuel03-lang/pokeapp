# Copier vers .env.local et renseigner les valeurs.
# Clerk — clés : https://dashboard.clerk.com → API Keys

VITE_CLERK_PUBLISHABLE_KEY=

# URLs d’auth (SPA) — doivent correspondre aux routes React (`App.tsx`)
VITE_CLERK_SIGN_IN_URL=/sign-in
VITE_CLERK_SIGN_UP_URL=/sign-up
VITE_CLERK_AFTER_SIGN_IN_URL=/
VITE_CLERK_AFTER_SIGN_UP_URL=/
