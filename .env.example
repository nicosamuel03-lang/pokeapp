# Copier vers .env.local et renseigner les valeurs.
# Clerk — clés : https://dashboard.clerk.com → API Keys

VITE_CLERK_PUBLISHABLE_KEY=

# (Optionnel, Safari iOS PWA / session sans cookies tiers)
# Remplacer par l’URL du script clerk.js de ton instance, ex. :
# VITE_CLERK_JS_URL=https://<frontend-api>.clerk.accounts.dev/__clerk/clerk.js
# (Frontend API : Dashboard → API Keys → « Frontend API »)
VITE_CLERK_JS_URL=

# URLs d’auth (SPA) — doivent correspondre aux routes React (`App.tsx`)
# Équivalent comportement « after sign-in / after sign-up » (fallback redirects)
VITE_CLERK_SIGN_IN_URL=/sign-in
VITE_CLERK_SIGN_UP_URL=/sign-up
VITE_CLERK_AFTER_SIGN_IN_URL=/
VITE_CLERK_AFTER_SIGN_UP_URL=/

# --- Clerk Dashboard (recommandé pour iOS PWA) ---
# Configure → Sessions → activer « URL-based session syncing » si besoin
# Domains : ajouter l’URL de prod (ex. Vercel) ; configurer Satellite si multi-domaines
